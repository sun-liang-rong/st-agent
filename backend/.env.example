# 环境配置
APP_NAME=AI报表生成平台
APP_ENV=development
APP_DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# MySQL 数据库配置
DB_HOST=mysql5.sqlpub.com
DB_PORT=3310
