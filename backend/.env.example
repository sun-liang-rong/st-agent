# 商汤 AI API 配置
SHANGTANG_API_KEY=your-shangtang-api-key-here
SHANGTANG_PROMPT_MODEL=shangtang-model-a
SHANGTANG_IMAGE_MODEL=shangtang-model-b

# 书生大模型 API 配置
SENSENOVA_API_KEY=your-sensenova-api-key-here
SENSENOVA_PROMPT_MODEL=sensenova-6.7-flash-lite
SENSENOVA_IMAGE_MODEL=sensenova-u1-fast
SENSENOVA_API_BASE=https://token.sensenova.cn/v1

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 跨域配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 文件上传限制
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=xlsx,xls,csv
